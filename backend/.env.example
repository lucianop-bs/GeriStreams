# ============================================================
# GeriStreams - Variaveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores:
#   cp .env.example .env
#
# O arquivo .env NUNCA deve ser commitado (ja esta no .gitignore)
# ============================================================

# ---- Banco de Dados (PostgreSQL) ----
# Ajuste conforme sua instalacao local
DB_URL=jdbc:postgresql://localhost:5432/geristreams
DB_USERNAME=postgres
DB_PASSWORD=sua_senha_aqui

# ---- JWT (Autenticacao) ----
# Chave secreta para assinar tokens. Em producao, troque por uma chave forte.
JWT_SECRET=geristreams-secret-key-must-be-at-least-256-bits-long-for-hs256

# ---- Anthropic / Claude AI (opcional) ----
# Obtenha sua chave em: https://console.anthropic.com/settings/keys
# Sem essa chave o sistema funciona normalmente, apenas as dicas de IA ficam indisponiveis.
ANTHROPIC_API_KEY=
